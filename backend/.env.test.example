# Banco de TESTE isolado — nunca use a URL de producao aqui
# Copie este arquivo para .env.test e configure o banco de teste
# IMPORTANTE: .env.test nao deve ser commitado (ja esta no .gitignore)

# Opcao A: Segundo projeto Supabase (recomendado)
# DATABASE_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Opcao B: PostgreSQL local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/erp_test"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/erp_test"

# Opcao C: Docker (porta diferente para nao conflitar)
# DATABASE_URL="postgresql://postgres:test@localhost:5433/postgres"
# DIRECT_URL="postgresql://postgres:test@localhost:5433/postgres"

DATABASE_URL=""
DIRECT_URL=""
PORT=3000
