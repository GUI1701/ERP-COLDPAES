generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

enum TipoItem {
  PRODUTO
  INSUMO
}

enum TipoMovimento {
  ENTRADA
  SAIDA
  AJUSTE
}

enum TipoLancamento {
  RECEITA
  DESPESA
}

enum StatusLancamento {
  PREVISTO
  REALIZADO
}

model Item {
  id            String             @id @default(cuid())
  nome          String
  tipo          TipoItem
  unidade       String
  saldoAtual    Decimal            @default(0)
  estoqueMinimo Decimal
  estoqueIdeal  Decimal
  ultimoCusto   Decimal?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  movimentos    MovimentoEstoque[]
  itensVenda    ItemVenda[]
  itensCompra   ItemCompra[]
}

model MovimentoEstoque {
  id         String        @id @default(cuid())
  itemId     String
  tipo       TipoMovimento
  quantidade Decimal
  motivo     String?
  createdAt  DateTime      @default(now())
  item       Item          @relation(fields: [itemId], references: [id])
}

model Lancamento {
  id             String           @id @default(cuid())
  descricao      String
  tipo           TipoLancamento
  status         StatusLancamento
  valor          Decimal
  dataVencimento DateTime
  dataEfetivacao DateTime?
  vendaId        String?
  compraId       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  venda          Venda?           @relation(fields: [vendaId], references: [id])
  compra         Compra?          @relation(fields: [compraId], references: [id])
}

model Cliente {
  id         String   @id @default(cuid())
  nome       String
  telefone   String?
  email      String?
  cidade     String?
  observacao String?
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vendas     Venda[]
}

model Venda {
  id          String       @id @default(cuid())
  cliente     String?
  clienteId   String?
  clienteRel  Cliente?     @relation(fields: [clienteId], references: [id])
  data        DateTime     @default(now())
  observacao  String?
  total       Decimal
  createdAt   DateTime     @default(now())
  itens       ItemVenda[]
  lancamentos Lancamento[]

  @@index([clienteId])
}

model ItemVenda {
  id         String  @id @default(cuid())
  vendaId    String
  itemId     String
  quantidade Decimal
  valorUnit  Decimal
  venda      Venda   @relation(fields: [vendaId], references: [id])
  item       Item    @relation(fields: [itemId], references: [id])
}

model Fornecedor {
  id         String   @id @default(cuid())
  nome       String
  telefone   String?
  email      String?
  cidade     String?
  observacao String?
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  compras    Compra[]
}

model Compra {
  id            String       @id @default(cuid())
  fornecedor    String?
  fornecedorId  String?
  fornecedorRel Fornecedor?  @relation(fields: [fornecedorId], references: [id])
  data          DateTime     @default(now())
  observacao    String?
  total         Decimal
  createdAt     DateTime     @default(now())
  itens         ItemCompra[]
  lancamentos   Lancamento[]

  @@index([fornecedorId])
}

model ItemCompra {
  id         String  @id @default(cuid())
  compraId   String
  itemId     String
  quantidade Decimal
  valorUnit  Decimal
  compra     Compra  @relation(fields: [compraId], references: [id])
  item       Item    @relation(fields: [itemId], references: [id])
}

model Configuracao {
  id    String @id @default(cuid())
  chave String @unique
  valor String
}
